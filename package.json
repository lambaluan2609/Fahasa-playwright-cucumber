{
  "name": "fahasa-playwright",
  "version": "2.0.0",
  "description": "Cucumber BDD + Playwright TypeScript E2E tests for Fahasa website",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:qa": "cross-env ENV=qa cucumber-js",
    "test:stg": "cross-env ENV=stg cucumber-js",
    "test:dev": "cross-env ENV=dev cucumber-js",
    "test:headed": "cross-env HEADED=true cucumber-js",
    "test:headless": "cucumber-js",
    "test:chrome": "cross-env BROWSER=chrome cucumber-js",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js",
    "test:safari": "cross-env BROWSER=safari cucumber-js",
    "test:login": "cucumber-js --tags @login",
    "test:search": "cucumber-js --tags @search",
    "test:cart": "cucumber-js --tags @cart",
    "test:checkout": "cucumber-js --tags @checkout",
    "test:smoke": "cucumber-js --tags @smoke",
    "test:regression": "cucumber-js --tags @regression",
    "test:pass": "cucumber-js --tags @pass",
    "test:fail": "cucumber-js --tags @fail",
    "test:data-driven": "cucumber-js --tags @data-driven",
    "test:parallel": "cucumber-js --parallel 4",
    "test:qa:headed": "cross-env ENV=qa HEADED=true cucumber-js",
    "test:stg:headed": "cross-env ENV=stg HEADED=true cucumber-js",
    "test:dev:headed": "cross-env ENV=dev HEADED=true cucumber-js",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run report:open"
  },
  "keywords": [
    "cucumber",
    "playwright",
    "typescript",
    "bdd",
    "e2e",
    "fahasa",
    "allure"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@cucumber/messages": "^32.2.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "allure-commandline": "^2.30.0",
    "allure-cucumberjs": "^3.0.0",
    "cross-env": "^7.0.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.50.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
